<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Form</class>
 <widget class="QWidget" name="Form">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1366</width>
    <height>768</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>1200</width>
    <height>700</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>Image Studio</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* ========================================
   STYLESHEET SECTION - Professional Gradient Theme
   Theme Colors: Purple/Blue Gradient (#667eea, #764ba2)
   Dark Background: #0f1419, #1a202c, #2d3748
   ======================================== */

/* Main Window */
QMainWindow, QWidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #0f1419, stop:1 #1a1f2e);
    color: #e4e8f0;
    font-family: 'Segoe UI Semibold', 'Segoe UI';
    font-size: 12px;
}

/* Labels */
QLabel {
    color: #e4e8f0;
    font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    font-size: 12px;
}

/* Buttons */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1f1f3d, stop:1 #0f0f25);
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
    min-height: 24px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #2d2d5f, stop:1 #1a1a38);
    border: 2px solid #764ba2;
    color: #ffffff;
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #7c3aed;
    color: #ffffff;
}

QPushButton#btnUploadOriginal {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
    color: #ffffff;
    min-width: 98px;
}

QPushButton#btnUploadOriginal:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #764ba2, stop:1 #9333ea);
    border: 2px solid #7c3aed;
    color: #ffffff;
}

QPushButton#btnReset {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1f1f3d, stop:1 #0f0f25);
    border-color: #5674ff;
    min-width: 58px;
}

QPushButton#btnUploadMatchImage1, QPushButton#btnUploadMatchImage2 {
    min-width: 24px;
    max-width: 24px;
    min-height: 24px;
    max-height: 24px;
    padding: 0;
    border-radius: 6px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1f1f3d, stop:1 #0f0f25);
    border: 2px solid #667eea;
}

QPushButton#btnUploadMatchImage1:hover, QPushButton#btnUploadMatchImage2:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #2d2d5f, stop:1 #1a1a38);
    border: 2px solid #764ba2;
}

/* Input Fields */
QComboBox, QSpinBox, QDoubleSpinBox {
    background-color: #1a202c;
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 6px;
    padding: 5px 8px;
    font-size: 11px;
    selection-background-color: #764ba2;
}

QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border: 2px solid #764ba2;
    background-color: #1f2937;
}

QComboBox::drop-down {
    border: none;
    width: 22px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #667eea;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: #1a202c;
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 8px;
    selection-background-color: #667eea;
    padding: 4px;
}

/* Group Boxes */
QGroupBox {
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 12px;
    margin-top: 12px;
    font-weight: 600;
    font-size: 13px;
    padding: 10px 8px 8px 8px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1a1a36, stop:1 #0f0f1f);
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 3px 12px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border-radius: 6px;
    color: #ffffff;
    font-weight: bold;
    font-size: 12px;
}

/* Checkboxes */
QCheckBox {
    color: #e4e8f0;
    font-size: 12px;
    spacing: 8px;
    padding: 4px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid #667eea;
    border-radius: 6px;
    background-color: #1a202c;
}

QCheckBox::indicator:hover {
    border: 2px solid #764ba2;
    background-color: #1f2937;
}

QCheckBox::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
    image: none;
}

/* Radio Buttons */
QRadioButton {
    color: #e4e8f0;
    font-size: 12px;
    spacing: 8px;
    padding: 4px;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #667eea;
    border-radius: 9px;
    background-color: #1a202c;
}

QRadioButton::indicator:hover {
    border: 2px solid #764ba2;
    background-color: #1f2937;
}

QRadioButton::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
}

/* Sliders */
QSlider::groove:horizontal {
    background: #1a202c;
    height: 8px;
    border-radius: 4px;
    border: 1px solid #667eea;
}

QSlider::handle:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
    width: 18px;
    margin: -6px 0;
    border-radius: 9px;
}

QSlider::handle:horizontal:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #764ba2, stop:1 #9333ea);
    border: 2px solid #7c3aed;
}

QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border-radius: 4px;
}

/* Scroll Area */
QScrollArea {
    border: none;
    background: transparent;
}

QScrollBar:vertical {
    background-color: #0f0f25;
    width: 12px;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #764ba2, stop:1 #9333ea);
}

/* Custom Frames */
#topBar {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #0f1419, stop:1 #1a1f2e);
}

#leftImageFrame, #rightImageFrame {
    border: 3px solid #667eea;
    border-radius: 12px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #0f0f25, stop:1 #0a0a15);
}

#matchImage1Frame, #matchImage2Frame, #matchResultFrame {
    border: 3px solid #667eea;
    border-radius: 12px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #0f0f25, stop:1 #0a0a15);
}

#lblSingleOriginalTitle, #lblSingleOutputTitle {
    font-size: 28px;
    font-weight: 700;
    color: #667eea;
}

#lblImg1Title, #lblImg2Title {
    border: 0;
    background-color: transparent;
    padding: 1px 2px;
    font-weight: 700;
    font-size: 14px;
    color: #e4e8f0;
}

#lblOriginal, #lblProcessed, #lblMatchImage1, #lblMatchImage2, #lblMatchResult {
    border: 0;
    background-color: transparent;
    color: #8892b0;
    font-size: 16px;
    font-weight: 500;
}

#hDivider {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                      stop:0 #667eea, stop:1 #764ba2);
    min-height: 2px;
    max-height: 2px;
}

#frameHarris, #frameLambda, #frameSift, #frameMatching, #matchSideFrame {
    border: 2px solid #667eea;
    border-radius: 14px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1a1a36, stop:1 #0f0f1f);
}

#matchThreshold, #matchCount {
    background-color: #1a202c;
    border: 2px solid #667eea;
    border-radius: 6px;
    min-height: 20px;
    padding: 2px 4px;
    color: #e4e8f0;
}

#lblMatchUsing {
    font-size: 24px;
    font-weight: 700;
    padding-top: 6px;
    padding-bottom: 4px;
    color: #667eea;
}

QLabel[chipTitle=&quot;true&quot;] {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 1px solid #aebdff;
    border-radius: 8px;
    color: #edf2ff;
    font-weight: 700;
}

#topTimeFrame {
    border-radius: 8px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1a1a36, stop:1 #0f0f1f);
    border: 1px solid #667eea;
}

#matchTimeFrame {
    border-radius: 8px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1a1a36, stop:1 #0f0f1f);
    border: 1px solid #667eea;
}

QMenuBar, QMenu {
    background-color: #0f1419;
    color: #e4e8f0;
    border-bottom: 1px solid #667eea;
}

QMenuBar::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    color: #ffffff;
}</string>
